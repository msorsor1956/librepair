{
  "version": 2,
  "buildCommand": "cd packages/web && bun install && bun run build",
  "outputDirectory": "packages/web/dist",
  "installCommand": "bun install",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.ts": {
      "runtime": "nodejs20.x"
    }
  }
}
